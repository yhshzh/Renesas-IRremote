[
  {
    "name": "ARM GCC - RA4M2 App",
    "description": "RA4M2 application firmware: ESP-AT transport, IR RX external IRQ, IR TX GPT carrier.",
    "toolchainFile": "${workspaceFolder}/cmake/gcc.cmake",
    "cmakeSettings": {
      "ARM_TOOLCHAIN_PATH": "/usr/bin",
      "CMAKE_BUILD_TYPE": "Debug",
      "IRREMOTE_RA4M2_RECV_DEMO": "OFF",
      "IRREMOTE_RA4M2_SEND_DEMO": "OFF",
      "IRREMOTE_RA4M2_USE_IRQ_RECV": "ON",
      "IRREMOTE_RA4M2_USE_SYSTICK_RECV": "OFF",
      "IRREMOTE_RA4M2_USE_GPT_SEND": "ON",
      "IRREMOTE_RA4M2_RECV_BUFFER_SIZE": "1024",
      "IRREMOTE_RA4M2_RECV_TIMEOUT_MS": "50",
      "IRREMOTE_RA4M2_DEBUG_RAW_DUMP_SIZE": "1024"
    },
    "preferredGenerator": {
      "name": "Ninja"
    },
    "isTrusted": true
  },
  {
    "name": "ARM GCC - RA4M2 App Release",
    "description": "Release build of the RA4M2 application firmware with the same hardware configuration.",
    "toolchainFile": "${workspaceFolder}/cmake/gcc.cmake",
    "cmakeSettings": {
      "ARM_TOOLCHAIN_PATH": "/usr/bin",
      "CMAKE_BUILD_TYPE": "Release",
      "IRREMOTE_RA4M2_RECV_DEMO": "OFF",
      "IRREMOTE_RA4M2_SEND_DEMO": "OFF",
      "IRREMOTE_RA4M2_USE_IRQ_RECV": "ON",
      "IRREMOTE_RA4M2_USE_SYSTICK_RECV": "OFF",
      "IRREMOTE_RA4M2_USE_GPT_SEND": "ON",
      "IRREMOTE_RA4M2_RECV_BUFFER_SIZE": "1024",
      "IRREMOTE_RA4M2_RECV_TIMEOUT_MS": "50",
      "IRREMOTE_RA4M2_DEBUG_RAW_DUMP_SIZE": "1024"
    },
    "preferredGenerator": {
      "name": "Ninja"
    },
    "isTrusted": true
  }
]
