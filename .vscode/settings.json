{
  "cmake.configureOnOpen": true,
  "cmake.configureOnEdit": true,
  "cmake.useCMakePresets": "never",
  "cmake.options.statusBarVisibility": "visible",
  "cmake.sourceDirectory": "${workspaceFolder}",
  "cmake.buildDirectory": "${workspaceFolder}/build/${buildType}",
  "cmake.preferredGenerators": [
    "Ninja",
    "MinGW Makefiles",
    "Unix Makefiles"
  ],
  "cmake.debugConfig": {
      "name": "RA4M2 attach pyOCD",
      "type": "cortex-debug",
      "request": "attach",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/Renesas_IRremote.elf",
      "servertype": "external",
      "gdbTarget": "localhost:3333",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "raw"
    },
  "clangd.arguments": [
    "--query-driver=${env:ARM_GCC_TOOLCHAIN_PATH}*",
    "--compile-commands-dir=${workspaceFolder}",
    "--background-index"
  ],
  "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",
  "cortex-debug.pyocdPath": "${workspaceFolder}/.venv/bin/pyocd",
  "cortex-debug.gdbPath": "arm-none-eabi-gdb"
}